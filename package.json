{
  "name": "syncforge",
  "version": "0.4.0",
  "description": "Real-time collaboration for local development projects",
  "main": "dist/agent.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "server": "tsx src/server.ts",
    "init": "tsx src/agent.ts init",
    "start": "tsx src/agent.ts start",
    "update": "node scripts/update.mjs",
    "update:check": "node scripts/update.mjs --check",
    "uninstall": "node scripts/uninstall.mjs"
  },
  "bin": {
    "syncforge": "./bin/syncforge.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/katrate/syncforge.git"
  },
  "bugs": {
    "url": "https://github.com/katrate/syncforge/issues"
  },
  "homepage": "https://github.com/katrate/syncforge#readme",
  "keywords": [
    "sync",
    "collaboration",
    "realtime",
    "development",
    "file-sync",
    "websocket",
    "pair-programming",
    "live-share"
  ],
  "author": "katrate",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "minimatch": "^10.2.5",
    "ora": "^9.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10"
  }
}
